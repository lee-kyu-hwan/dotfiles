# Taps
tap "laishulu/homebrew"

# CLI Tools
brew "awscli"
brew "gh"
brew "git"
brew "git-lfs"
brew "node"
brew "pnpm"
brew "pipx"
brew "python@3.12"
brew "ripgrep"
brew "starship"
brew "stow"
