set -g mouse on

# ============================================================
# 클립보드 및 복사 설정 (OSC 52 지원)
# ============================================================
# tmux가 터미널(Ghostty)에 클립보드 내용을 전달하도록 허용
set -s set-clipboard on

# 복사 모드 (VI 스타일) 활성화
set-window-option -g mode-keys vi

# 선택 및 복사 단축키 (Vim 스타일)
bind-key -T copy-mode-vi v send-keys -X begin-selection
bind-key -T copy-mode-vi y send-keys -X copy-selection-and-cancel

# 마우스 드래그 복사 비활성화 (의도치 않은 복사 방지)
# 복사는 prefix+[ → v선택 → y복사 키보드 워크플로우 사용
unbind-key -T copy-mode-vi MouseDragEnd1Pane

# "0"번 세션 이름을 "main"으로 자동 변경
set-hook -g session-created 'if -F "#{==:#{session_name},0}" "rename-session main"'

{{ if eq .chezmoi.os "darwin" -}}
# ============================================================
# 한글 입력 호환 설정 (macOS only)
# ============================================================

# --- 1. Ctrl+B 누르는 순간 영문 전환 (핵심) ---
set -g prefix M-F12
bind -n C-b switch-client -T prefix \; run-shell -b "macism com.apple.keylayout.ABC"
bind C-b send-keys C-b

# --- 1-1. 자음 바인딩 (안전망) ---
bind ㅈ choose-tree -Zw         # w
bind ㅊ new-window              # c
bind ㄷ detach-client            # d
bind ㅜ next-window              # n
bind ㅍ previous-window          # p
bind ㅌ confirm-before -p "kill-pane #P? (y/n)" kill-pane  # x
bind ㅋ resize-pane -Z           # z
bind ㄴ choose-tree -Zs          # s
bind ㅐ select-pane -t :.+       # o
bind ㅣ select-layout next       # l
bind ㅂ display-panes            # q
bind ㅅ clock-mode               # t

# --- 2. macism 훅 (상태 초기화) ---
set-hook -g after-select-pane   'run-shell -b "macism com.apple.keylayout.ABC"'
set-hook -g after-select-window 'run-shell -b "macism com.apple.keylayout.ABC"'
set-hook -g pane-focus-in       'run-shell -b "macism com.apple.keylayout.ABC"'

# --- 3. 명령어 모드 강제 전환 ---
bind : run-shell "macism com.apple.keylayout.ABC" \; command-prompt

{{ else -}}
# ============================================================
# Linux: 표준 prefix
# ============================================================
set -g prefix C-b
bind C-b send-prefix

{{ end -}}
# ============================================================
# 직관적인 패널 분할 (현재 경로 유지)
# ============================================================
bind | split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"

# ============================================================
# 설정 리로드
# ============================================================
bind r source-file ~/.tmux.conf \; display-message "tmux.conf 리로드 완료"

# ============================================================
# 화면 + 스크롤백 클리어 (prefix + C-l, vim-tmux-navigator가 C-l 사용)
# ============================================================
bind C-l send-keys -R C-l \; clear-history

# ============================================================
# Pane 구분: 비활성 pane 어둡게 처리
# ============================================================
set -g window-style 'bg=colour238'
set -g window-active-style 'bg=colour0'
set -g pane-border-style fg=colour238
set -g pane-active-border-style fg=colour51

# ============================================================
# Pane 레이아웃 정렬 (상단 55%, 하단 2개 50:50)
# ============================================================
bind = set-window-option main-pane-height 55% \; select-pane -t 0 \; select-layout main-horizontal

# ============================================================
# OSC 시퀀스 패스스루
# ============================================================
set -g allow-passthrough on

# ============================================================
# 상태바
# ============================================================

# 스타일
set -g status-style "bg=colour236,fg=colour248"
set -g status-left-length 30
set -g status-right-length 60

# 왼쪽: 세션 이름
set -g status-left "#[fg=colour16,bg=colour75,bold] #S #[fg=colour75,bg=colour236] "

# 오른쪽: 날짜/시간
set -g status-right "#[fg=colour248] %m/%d %H:%M "

# 윈도우 탭: 비활성 (상태별 색상 분기)
#   activity (출력 중)    = 초록 ● (진행 중)
#   silence (10초 무출력) = 빨강 ⏸ (작업 완료/대기 — 확인 필요)
#   일반                  = 회색 (idle)
set -g window-status-format "#{?window_silence_flag,#[fg=colour196 bold] #I #W ⏸ ,#{?window_activity_flag,#[fg=colour46 bold] #I #W ● , #I #W }}"

# 윈도우 탭: 현재 활성
set -g window-status-current-format "#[fg=colour16,bg=colour39,bold] #I #W "

# Activity + Silence 모니터링
set -g monitor-activity on
set -g monitor-silence 20
set -g visual-activity off
set -g visual-silence off

# 구분선
set -g window-status-separator ""

# 상태바 위치
set -g status-position bottom

# 상태바 갱신 주기 (초)
set -g status-interval 5

set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'christoomey/vim-tmux-navigator'
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'tmux-plugins/tmux-continuum'

# resurrect: pane 내용 캡처 + 저장 경로 지정
set -g @resurrect-capture-pane-contents 'on'
set -g @resurrect-dir '~/.local/share/tmux/resurrect'

# continuum: 15분마다 자동 저장 + tmux 시작 시 자동 복원
set -g @continuum-restore 'on'
set -g @continuum-save-interval '15'

run '~/.tmux/plugins/tpm/tpm'
